/*--------------------------------*- C++ -*----------------------------------*\
| EBM Simulation | fvSolution | PIMPLE + GAMG/PBiCGStab                      |
\*---------------------------------------------------------------------------*/
FoamFile { version 2.0; format ascii; class dictionary; location "system"; object fvSolution; }

solvers
{
    "p_rgh.*"
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0.01;
        maxIter         100;
        nPreSweeps      0;
        nPostSweeps     2;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 20;
        agglomerator    faceAreaPair;
        mergeLevels     1;
    }
    p_rghFinal { $p_rgh; tolerance 1e-9; relTol 0.0; }

    "U.*"       { solver PBiCGStab; preconditioner DILU; tolerance 1e-8; relTol 0.1; maxIter 50; }
    UFinal      { $U; tolerance 1e-9; relTol 0.0; }

    "h.*"       { solver PBiCGStab; preconditioner DILU; tolerance 1e-9; relTol 0.01; maxIter 200; }
    hFinal      { $h; tolerance 1e-10; relTol 0.0; }

    "rho.*"     { solver diagonal; tolerance 1e-8; relTol 0.0; }

    "(k|omega|epsilon).*" { solver PBiCGStab; preconditioner DILU; tolerance 1e-7; relTol 0.1; }
}

PIMPLE
{
    nOuterCorrectors            3;
    nCorrectors                 2;
    nNonOrthogonalCorrectors    2;
    momentumPredictor           yes;
    turbOnFinalIterOnly         false;
    pRefCell                    0;
    pRefValue                   0.0;

    residualControl
    {
        U      { tolerance 1e-5; relTol 0.0; }
        p_rgh  { tolerance 1e-5; relTol 0.0; }
        h      { tolerance 1e-6; relTol 0.0; }
    }
}

relaxationFactors
{
    equations { U 0.7; h 0.5; ".*" 0.7; }
}
